# ── Database (Supabase) ───────────────────────────────────────
# Get from: Supabase → Project Settings → Database → Connection string (URI mode)
# IMPORTANT: append ?pgbouncer=true&connection_limit=1 for pooled connection
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ── Redis (local Docker on Oracle) ────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ── AI ────────────────────────────────────────────────────────
# Claude (required) — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Groq for Whisper voice transcription — console.groq.com
GROQ_API_KEY=gsk_...

# OpenAI for product embeddings (pgvector) — platform.openai.com
OPENAI_API_KEY=sk-...

# ── Payments (Monnify) ─────────────────────────────────────────
# Get from Monnify dashboard → Developers → API Keys
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_BASE_URL=https://sandbox.monnify.com

# ── WhatsApp vendor worker ────────────────────────────────────
# Which vendor DB row this worker instance handles
VENDOR_ID=1

# ── Optional ──────────────────────────────────────────────────
GEMINI_API_KEY=
