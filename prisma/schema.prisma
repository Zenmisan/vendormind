generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

model Vendor {
  id            BigInt            @id @default(autoincrement())
  name          String
  email         String            @unique
  phoneNumber   String?           @unique
  walletBalance Decimal           @default(0) @db.Decimal(10, 4)
  createdAt     DateTime          @default(now()) @db.Timestamptz
  updatedAt     DateTime          @updatedAt @db.Timestamptz
  sessions      WhatsAppSession[]
  products      Product[]
  customers     Customer[]
  orders        Order[]
  documents     Document[]

  @@map("vendors")
}

model WhatsAppSession {
  id        BigInt   @id @default(autoincrement())
  vendorId  BigInt
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  sessionId String   @unique
  data      Json // For Baileys auth state
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@index([vendorId])
  @@map("whatsapp_sessions")
}

model Product {
  id          BigInt                      @id @default(autoincrement())
  vendorId    BigInt
  vendor      Vendor                      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal                     @db.Decimal(10, 2)
  stock       Int                         @default(0)
  imageUrl    String?
  embedding   Unsupported("vector(1536)")? // For OpenAI embeddings, adjusted if using others
  createdAt   DateTime                    @default(now()) @db.Timestamptz
  updatedAt   DateTime                    @updatedAt @db.Timestamptz
  orderItems  OrderItem[]
  cartItems   CartItem[]

  @@index([vendorId])
  @@map("products")
}

model Customer {
  id          BigInt     @id @default(autoincrement())
  vendorId    BigInt
  vendor      Vendor     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  phoneNumber String
  name        String?
  createdAt   DateTime   @default(now()) @db.Timestamptz
  updatedAt   DateTime   @updatedAt @db.Timestamptz
  orders      Order[]
  cart        Cart?
  sessions    wa_session? // If we need to track WhatsApp specific session data outside of auth

  @@unique([vendorId, phoneNumber])
  @@map("customers")
}

model Order {
  id          BigInt      @id @default(autoincrement())
  vendorId    BigInt
  vendor      Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  customerId  BigInt
  customer    Customer    @relation(fields: [customerId], references: [id])
  total       Decimal     @db.Decimal(10, 2)
  status      String      @default("PENDING") // PENDING, PAID, CANCELED, DELIVERED
  createdAt   DateTime    @default(now()) @db.Timestamptz
  updatedAt   DateTime    @updatedAt @db.Timestamptz
  items       OrderItem[]
  paymentLink String?

  @@index([vendorId])
  @@index([customerId])
  @@map("orders")
}

model OrderItem {
  id        BigInt  @id @default(autoincrement())
  orderId   BigInt
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId BigInt
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  @@map("order_items")
}

model Cart {
  id         BigInt     @id @default(autoincrement())
  customerId BigInt     @unique
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      CartItem[]
  updatedAt  DateTime   @updatedAt @db.Timestamptz

  @@map("carts")
}

model CartItem {
  id        BigInt  @id @default(autoincrement())
  cartId    BigInt
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId BigInt
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int

  @@map("cart_items")
}

// Temporary session data for Baileys/Inbound context
model wa_session {
  id         BigInt   @id @default(autoincrement())
  customerId BigInt   @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  context    Json? // Rolling summary, last messages, etc.
  updatedAt  DateTime @updatedAt @db.Timestamptz

  @@map("wa_sessions_context")
}

model Document {
  id        BigInt                      @id @default(autoincrement())
  vendorId  BigInt
  vendor    Vendor                      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  title     String?
  content   String
  embedding Unsupported("vector(1536)")?
  createdAt DateTime                    @default(now()) @db.Timestamptz
  updatedAt DateTime                    @updatedAt @db.Timestamptz

  @@index([vendorId])
  @@map("documents")
}
