{
  "name": "vendormind",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": ["dashboard"],
  "scripts": {
    "dev": "docker compose up -d && bunx pm2 start ecosystem.config.cjs --no-daemon",
    "start": "bunx pm2 start ecosystem.config.cjs && bunx pm2 logs",
    "stop": "bunx pm2 stop all && bunx pm2 delete all",
    "restart": "bunx pm2 restart all",
    "logs": "bunx pm2 logs",
    "status": "bunx pm2 status",
    "db:migrate": "bunx prisma migrate dev",
    "db:studio": "bunx prisma studio",
    "db:generate": "bunx prisma generate",
    "db:seed": "bun run prisma/seed.ts",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:oracle": "docker compose -f docker-compose.oracle.yml up -d",
    "deploy:oracle": "docker compose -f docker-compose.oracle.yml up -d && bunx prisma migrate deploy && bun run start",
    "deploy:firebase": "cd dashboard && bun run build && bunx firebase deploy --only hosting",
    "test": "bun run scripts/verify.ts",
    "repl": "bun run scripts/test-loop.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ioredis": "^5.0.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/pino": "^7.0.5",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@google/generative-ai": "^0.24.1",
    "@hapi/boom": "^10.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "bullmq": "^5.78.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "groq-sdk": "^1.2.1",
    "ioredis": "^5.11.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pm2": "^7.0.1",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  }
}
